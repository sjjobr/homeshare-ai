# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=4000
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/homeshare

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Tavus AI (get from https://platform.tavus.io)
TAVUS_API_KEY=tvs-xxxxxxxxxxxxxxxxxxxx
TAVUS_PERSONA_ID=p8a304e4f7f9
TAVUS_REPLICA_ID=r38172bb38dc
TAVUS_WEBHOOK_SECRET=your-webhook-secret

# AWS S3 (for room photos) - optional
